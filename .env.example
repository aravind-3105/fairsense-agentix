# FairSense-AgentiX Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All settings use the FAIRSENSE_ prefix
# See fairsense_agentix/configs/settings.py for full documentation

# =============================================================================
# LLM Configuration (Phase 5.2: LangChain Integration)
# =============================================================================

# LLM Provider: openai | anthropic | local | fake
# - openai: Uses GPT-4/GPT-3.5 via LangChain's ChatOpenAI
# - anthropic: Uses Claude via LangChain's ChatAnthropic
# - fake: Uses fake LLM for testing (no API key needed)
FAIRSENSE_LLM_PROVIDER=openai

# Model name (provider-specific):
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-sonnet-20240229
FAIRSENSE_LLM_MODEL_NAME=gpt-4o

# API Key (REQUIRED for openai/anthropic, leave empty for fake)
# OpenAI: Get from https://platform.openai.com/api-keys
# Anthropic: Get from https://console.anthropic.com/settings/keys
FAIRSENSE_LLM_API_KEY=your-api-key-here

# Temperature (0.0 = deterministic, 1.0 = creative)
# Recommended: 0.3 for bias detection (consistent analysis)
FAIRSENSE_LLM_TEMPERATURE=0.3

# Max tokens to generate per LLM call
FAIRSENSE_LLM_MAX_TOKENS=2000

# Timeout for LLM API calls (seconds)
FAIRSENSE_LLM_TIMEOUT_SECONDS=60

# Enable LangChain SQLite caching for LLM responses
# Recommended: true (saves API costs, faster repeated queries)
FAIRSENSE_LLM_CACHE_ENABLED=true

# Path to SQLite cache database
# Cache is content-addressed using SHA256(model, prompt, params)
FAIRSENSE_LLM_CACHE_PATH=.cache/langchain.db

# =============================================================================
# OCR Configuration (Phase 5.3 - Complete)
# =============================================================================

# OCR Tool: auto (GPU-adaptive) | paddleocr (GPU/best) | tesseract (CPU/fast) | fake (testing)
# Recommended: auto (detects GPU and picks optimal tool)
# - GPU available: Uses PaddleOCR (10-50ms, 95%+ accuracy, handles rotated text)
# - CPU only: Uses Tesseract (50-100ms, 85-90% accuracy, 100+ languages)
FAIRSENSE_OCR_TOOL=auto

# Force CPU for OCR even if GPU available (for testing/debugging)
FAIRSENSE_OCR_FORCE_CPU=false

# OCR Language (ISO 639-2 codes: eng, fra, spa, deu, chi_sim, etc.)
FAIRSENSE_OCR_LANGUAGE=eng

# OCR confidence threshold (0.0-1.0)
# Only text with confidence >= threshold is included
# Higher threshold = fewer false positives, might miss some real text
FAIRSENSE_OCR_CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# Image Captioning Configuration (Phase 5.3 - Complete)
# =============================================================================

# Caption Model: auto (GPU-adaptive) | blip2 (GPU/best) | blip (CPU/fast) | fake (testing)
# Recommended: auto (detects GPU and picks optimal model)
# - GPU available: Uses BLIP-2 (50-200ms, excellent quality, state-of-the-art)
# - CPU only: Uses BLIP (500ms-1s, good quality, acceptable speed)
FAIRSENSE_CAPTION_MODEL=auto

# Force CPU for captioning even if GPU available (for testing/debugging)
FAIRSENSE_CAPTION_FORCE_CPU=false

# Preload caption model at startup (recommended: true for production)
# true: 5-20s startup, 50ms-1s per call (fast API responses)
# false: 0s startup, 5-20s first call (better for development)
FAIRSENSE_CAPTION_PRELOAD=true

# Maximum caption length in tokens (default: 100)
FAIRSENSE_CAPTION_MAX_LENGTH=100

# =============================================================================
# Image Analysis Configuration
# =============================================================================

# Image bias analysis method: vlm | traditional
# - vlm: Vision-Language Model (GPT-4o/Claude); uses FAIRSENSE_LLM_*; fast, requires API
# - traditional: OCR + Caption + Text analysis; local models, no API
FAIRSENSE_IMAGE_ANALYSIS_MODE=vlm

# Validate image bytes with Pillow before processing (disable for synthetic tests)
FAIRSENSE_IMAGE_VALIDATION_ENABLED=true

# =============================================================================
# Embedding & FAISS Configuration (Phase 5.1 - Complete)
# =============================================================================

# Sentence embedding model from sentence-transformers
# Recommended: all-MiniLM-L6-v2 (384-dim, fast), all-mpnet-base-v2 (768-dim, accurate)
FAIRSENSE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimension (must match model)
# all-MiniLM-L6-v2: 384, all-mpnet-base-v2: 768
FAIRSENSE_EMBEDDING_DIMENSION=384

# FAISS index paths (relative to project root, resolved at server startup)
#
# IMPORTANT — path naming convention:
#   The value is a virtual ".faiss" path used only to derive the folder name.
#   The resolver strips the extension and looks for a LangChain-format folder:
#     e.g. "fairsense_agentix/data/indexes/risks.faiss"
#          → checks for  fairsense_agentix/data/indexes/risks/index.faiss
#
#   The bundled indexes live inside the package at:
#     fairsense_agentix/data/indexes/risks/index.faiss   (+ index.pkl)
#     fairsense_agentix/data/indexes/rmf/index.faiss     (+ index.pkl)
#
#   If the derived folder is missing or has no index.faiss, the system silently
#   falls back to FakeFAISSIndexTool which returns hardcoded placeholder results.
#
# Use the package-bundled indexes (recommended default):
FAIRSENSE_FAISS_RISKS_INDEX_PATH=fairsense_agentix/data/indexes/risks.faiss
FAIRSENSE_FAISS_RMF_INDEX_PATH=fairsense_agentix/data/indexes/rmf.faiss

# Number of top results to retrieve from FAISS
FAIRSENSE_FAISS_TOP_K=5

# =============================================================================
# Cache Configuration (Phase 8)
# =============================================================================

# Enable caching globally (recommended: True for development)
FAIRSENSE_CACHE_ENABLED=true

# Cache backend: memory | redis | filesystem
# - memory: Fast, process-local (lost on restart)
# - filesystem: Persistent across restarts
# - redis: Shared across processes (requires Redis server)
FAIRSENSE_CACHE_BACKEND=memory

# Cache TTL (time-to-live) in seconds
# LangChain LLM cache is separate and content-addressed (no TTL)
FAIRSENSE_CACHE_TTL_SECONDS=3600

# Cache directory (for filesystem backend)
FAIRSENSE_CACHE_DIR=.cache

# =============================================================================
# Telemetry & Observability Configuration (Phase 1 - Complete)
# =============================================================================

# Enable telemetry and detailed logging
FAIRSENSE_TELEMETRY_ENABLED=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
FAIRSENSE_LOG_LEVEL=INFO

# OpenTelemetry collector endpoint (optional)
# Leave empty to disable OTEL export
FAIRSENSE_OTEL_ENDPOINT=

# Trace all LLM calls (token usage, cost, latency)
# Recommended: true (enables cost tracking dashboards)
FAIRSENSE_TRACE_ALL_LLM_CALLS=true

# =============================================================================
# API Server Configuration (Phase 9 - Complete)
# =============================================================================

# API server host
FAIRSENSE_API_HOST=0.0.0.0

# API server port
FAIRSENSE_API_PORT=8000

# Auto-reload on code changes (development only)
FAIRSENSE_API_RELOAD=false

# =============================================================================
# Workflow & Orchestration Configuration (Phase 2-4 - Complete)
# =============================================================================

# Enable refinement loop (Phase 7)
# When true, evaluator can trigger re-execution of nodes
FAIRSENSE_ENABLE_REFINEMENT=true

# Maximum refinement iterations per workflow
FAIRSENSE_MAX_REFINEMENT_ITERATIONS=1

# Enable LLM-based evaluators for post-hoc quality checks
FAIRSENSE_EVALUATOR_ENABLED=true

# Minimum passing score for bias evaluator (0-100)
FAIRSENSE_BIAS_EVALUATOR_MIN_SCORE=75

# Risk evaluator: minimum unique RMF functions (1-4: Govern, Map, Measure, Manage)
FAIRSENSE_RISK_EVALUATOR_MIN_RMF_FUNCTIONS=3

# Risk evaluator: minimum average FAISS similarity score (0.0-1.0)
FAIRSENSE_RISK_EVALUATOR_MIN_AVG_SCORE=0.3

# Risk evaluator: minimum number of risks for coverage
FAIRSENSE_RISK_EVALUATOR_MIN_RISKS=3

# Similarity threshold for duplicate risk detection (0.0-1.0)
FAIRSENSE_RISK_DUPLICATE_THRESHOLD=0.9

# Timeout for entire workflow execution (seconds)
FAIRSENSE_WORKFLOW_TIMEOUT_SECONDS=300

# Router confidence threshold (0.0-1.0)
# Minimum confidence required to select a workflow
FAIRSENSE_ROUTER_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Bias Detection Configuration (Phase 5.2 - Complete)
# =============================================================================

# Bias categories to detect (JSON array format for Pydantic)
# Available: gender, age, racial, disability, socioeconomic
FAIRSENSE_BIAS_CATEGORIES=["gender","age","racial","disability","socioeconomic"]

# Highlight colors for bias types (hex codes for HTML rendering)
FAIRSENSE_BIAS_COLOR_GENDER="#FFB3BA"
FAIRSENSE_BIAS_COLOR_AGE="#FFDFBA"
FAIRSENSE_BIAS_COLOR_RACIAL="#FFFFBA"
FAIRSENSE_BIAS_COLOR_DISABILITY="#BAE1FF"
FAIRSENSE_BIAS_COLOR_SOCIOECONOMIC="#E0BBE4"

# =============================================================================
# Output & Persistence Configuration (Phase 5.4)
# =============================================================================

# Directory for saved output files (CSV, JSON, HTML)
FAIRSENSE_OUTPUT_DIR=outputs

# Maximum length for generated summaries (characters)
FAIRSENSE_SUMMARIZER_MAX_LENGTH=200

# =============================================================================
# Quick Start Examples
# =============================================================================

# Example 1: Local development with fake tools
# FAIRSENSE_LLM_PROVIDER=fake
# FAIRSENSE_OCR_TOOL=fake
# FAIRSENSE_CAPTION_MODEL=fake
# (No API keys needed, fast feedback loop)

# Example 2: Production with OpenAI
# FAIRSENSE_LLM_PROVIDER=openai
# FAIRSENSE_LLM_MODEL_NAME=gpt-4-turbo
# FAIRSENSE_LLM_API_KEY=sk-...
# FAIRSENSE_CACHE_ENABLED=true
# FAIRSENSE_TELEMETRY_ENABLED=true

# Example 3: Production with Anthropic Claude
# FAIRSENSE_LLM_PROVIDER=anthropic
# FAIRSENSE_LLM_MODEL_NAME=claude-3-5-sonnet-20241022
# FAIRSENSE_LLM_API_KEY=sk-ant-...
# FAIRSENSE_CACHE_ENABLED=true
# FAIRSENSE_TELEMETRY_ENABLED=true
